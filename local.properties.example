# Copy this file to `local.properties` (git-ignored) and fill in real values.

# UDID of the Android TV device. For a network-attached box use ip:port.
udid=192.168.50.207:5555

environment=dev
appiumHost=127.0.0.1
appiumPort=4732
manageAppium=false
# Attach screen recording to Allure for ALL tests (failures always attach video).
videoRecord=false

# Premium staging test account used by the API sign-in precondition.
# The TV welcome gate requires a premium account. Never commit real credentials.
tvEmail=
tvPassword=

# Server-list API v7 (encrypted). AES key used to decode the response. Never commit.
serverListKey=
# Optional overrides (defaults shown).
region=UA
serverlistUrl=https://dev-api.mobilejump.mobi
